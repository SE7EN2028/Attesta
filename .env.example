# Copy to .env and fill in with real values.
# Postgres (Neon / Vercel Postgres / Supabase). Prisma uses @prisma/adapter-pg.
# DATABASE_URL: pooled connection string (app runtime).
# DIRECT_URL:   direct/unpooled string (used by `prisma migrate`).
# (At small scale the same non-pooled string works for both.)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Deepgram pre-recorded transcription API — https://console.deepgram.com
DEEPGRAM_API_KEY="your-deepgram-api-key"

# Gemini API (generateContent) — used for report generation.
# https://aistudio.google.com/apikey
# Chosen over Groq/NIM: free-tier TPM ceiling is high enough for this app's
# ~40-50K-token prompts (Groq's free tier caps at 12K TPM; NIM hit a hard
# shared-pool capacity ceiling). Gemini's low free-tier RPM/RPD are
# request-count limits, not token-volume — not a bottleneck for this app's
# occasional, single-request usage pattern.
GEMINI_API_KEY="your-gemini-api-key"

# Model fallback chain (csv, first = primary). Code reads GEMINI_MODELS first,
# then GEMINI_MODEL, else a built-in default. Leave unset to use the default
# (gemini-2.5-flash,gemini-3.5-flash).
GEMINI_MODELS="gemini-2.5-flash,gemini-3.5-flash"

# Brevo transactional email API — https://www.brevo.com
# Used to send report-ready notifications to clients after admin locks a report.
# Get API key from Brevo dashboard; verify sender domain before sending.
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="reports@yourdomain.com"
EMAIL_FROM_NAME="Attesta"

# Base URL for building report links in email notifications.
APP_URL="http://localhost:3000"

# Session JWT signing secret (jsonwebtoken, HS256) — signs the attesta_uid
# session cookie. Generate a strong random value: `openssl rand -base64 32`.
# ⚠️ DEPLOY: this SAME value must be added to Vercel's Environment Variables
# before deploy, or every session verify fails in production.
JWT_SECRET="generate-with-openssl-rand-base64-32"

# Vercel Blob — stores uploaded source files (audio/docs). Create a Blob store
# in the Vercel dashboard (Storage → Create → Blob) and copy its read-write
# token here. Vercel auto-injects this in production once the store is linked.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Public sample report pinned on /samples (optional). Unset = most-recent
# locked report is used as the fallback.
SAMPLE_REPORT_ID=""
