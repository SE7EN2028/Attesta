# Copy to .env and fill in with real values.
# Local dev uses SQLite (no external setup needed).
DATABASE_URL="file:./dev.db"

# Switching to Postgres later (Vercel Postgres / Supabase / Neon / local):
# 1. DATABASE_URL="postgresql://user:password@localhost:5432/attesta?schema=public"
# 2. In prisma/schema.prisma: datasource db { provider = "postgresql" }
# 3. Reintroduce real `enum` blocks for tier/status/etc fields (see schema comments)

# Deepgram pre-recorded transcription API — https://console.deepgram.com
DEEPGRAM_API_KEY="your-deepgram-api-key"
