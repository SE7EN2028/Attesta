# Copy to .env and fill in with real values.
# Local dev uses SQLite (no external setup needed).
DATABASE_URL="file:./dev.db"

# Switching to Postgres later (Vercel Postgres / Supabase / Neon / local):
# 1. DATABASE_URL="postgresql://user:password@localhost:5432/attesta?schema=public"
# 2. In prisma/schema.prisma: datasource db { provider = "postgresql" }
# 3. Reintroduce real `enum` blocks for tier/status/etc fields (see schema comments)

# Deepgram pre-recorded transcription API — https://console.deepgram.com
DEEPGRAM_API_KEY="your-deepgram-api-key"

# Gemini API (generateContent) — used for report generation.
# https://aistudio.google.com/apikey
# Chosen over Groq/NIM: free-tier TPM ceiling is high enough for this app's
# ~40-50K-token prompts (Groq's free tier caps at 12K TPM; NIM hit a hard
# shared-pool capacity ceiling). Gemini's low free-tier RPM/RPD are
# request-count limits, not token-volume — not a bottleneck for this app's
# occasional, single-request usage pattern.
GEMINI_API_KEY="your-gemini-api-key"

# Brevo transactional email API — https://www.brevo.com
# Used to send report-ready notifications to clients after admin locks a report.
# Get API key from Brevo dashboard; verify sender domain before sending.
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="reports@yourdomain.com"
EMAIL_FROM_NAME="Attesta"

# Base URL for building report links in email notifications.
APP_URL="http://localhost:3000"
