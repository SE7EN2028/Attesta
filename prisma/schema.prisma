// Prisma schema for Attesta.
//
// Provider is sqlite for local dev (no external DB provisioning needed).
// Connection url lives in prisma.config.ts, read from DATABASE_URL.
//
// SQLite has no native enum support in Prisma, so fields that are
// conceptually enums are typed String with the allowed values documented
// in a comment. Swapping to Postgres later means: change provider to
// "postgresql", reintroduce real `enum` blocks below, and change these
// fields' types to those enums — no other structural changes needed.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  companyName String
  createdAt   DateTime @default(now())

  meetingRequests MeetingRequest[]
}

model MeetingRequest {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  company        String
  region         String
  governingBody  String
  meetingDate    DateTime
  title          String
  outputLanguage String
  tier           String // "ESSENTIAL" | "SCOPE" | "PREMIUM"
  status         String // "DRAFT" | "SUBMITTED" | "TRANSCRIBING" | "GENERATING" | "IN_REVIEW" | "LOCKED" | "DISPATCHED"
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sourceFiles SourceFile[]
  report      Report?
}

model SourceFile {
  id               String   @id @default(cuid())
  meetingRequestId String
  meetingRequest   MeetingRequest @relation(fields: [meetingRequestId], references: [id])
  type             String // "AUDIO" | "VIDEO" | "DOCX" | "PDF"
  role             String   @default("PRIMARY_MEETING") // "PRIMARY_MEETING" | "SUPPORTING_DOCUMENT"
  fileName         String
  storageUrl       String
  // Raw text pulled from DOCX/PDF supporting documents at upload time (no
  // Deepgram, no diarization — just so it's ready to feed into report
  // generation in Phase 5). Null for audio/video and for anything not
  // extracted yet.
  extractedText    String?
  uploadedAt       DateTime @default(now())

  transcript Transcript?
}

model Transcript {
  id            String   @id @default(cuid())
  sourceFileId  String   @unique
  sourceFile    SourceFile @relation(fields: [sourceFileId], references: [id])
  rawText       String
  speakerLabels Json // [{ speakerId, name, segments: [{ start, end, text }] }]
  source        String // "DEEPGRAM" | "MANUAL"
  createdAt     DateTime @default(now())
}

model Report {
  id               String   @id @default(cuid())
  meetingRequestId String   @unique
  meetingRequest   MeetingRequest @relation(fields: [meetingRequestId], references: [id])
  tier             String // "ESSENTIAL" | "SCOPE" | "PREMIUM"
  outputLanguage   String
  content          Json // { coverInfo, executiveSummary, attendance, agendaItems, discussionLog, decisions, votes, proceduralNotes, closingNotes }
  speakerAnalytics Json // [{ speakerName, talkTimeSeconds, contributionCount, onTopicScore }]
  numericalData    Json // [{ label, value, context }]
  // Which model provider actually produced this report — null for reports
  // that predate this field (e.g. seed data). Always "gemini" going
  // forward (see lib/report-generation.ts); older rows may still say
  // "deepseek" | "nim" | "groq" from before the provider swap.
  generatedBy      String? // "gemini" (legacy: "deepseek" | "nim" | "groq")
  status           String // "DRAFT" | "LOCKED"
  // Pre-generated executive-summary text-to-speech (Vercel Blob URL), produced
  // at generation time so the report viewer's "Listen" plays instantly instead
  // of synthesizing on click. Null = synthesize on demand (old rows / TTS
  // failed); the /listen route caches into this on first play.
  summaryAudioUrl  String?
  lockedAt         DateTime?
  lockedBy         String?
  dispatchedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  complianceFindings ComplianceFinding[]
}

// Single-use, expiring magic-link tokens for passwordless email sign-in. Only
// the SHA-256 hash of the token is stored (a DB leak exposes no usable link).
// The pending user's companyName rides along so the User row is created only on
// verification. Consumed (deleted) on successful sign-in.
model SignInToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  email       String
  companyName String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model ComplianceFinding {
  id                String @id @default(cuid())
  reportId          String
  report            Report @relation(fields: [reportId], references: [id])
  category          String // "RISK" | "MISSING_DOCUMENT" | "COMPLIANCE_REFERENCE" | "RECOMMENDATION" | "COMPLIANT"
  riskLevel         String // "CRITICAL" | "HIGH" | "MEDIUM" | "ADVISORY" | "COMPLIANT"
  description       String
  ruleReference     String?
  impactDescription String?
  confidence        Int // 0-100
}

// Admin-editable prompt overrides for the report engine. Only rows that exist
// override the hardcoded default; the resolver in lib/prompts.ts falls back to
// PROMPT_DEFAULTS (the single source of truth) when a key has no row, so an
// empty table means "all defaults". `key` matches a PromptKey in lib/prompts.ts.
// Only the instructional TEXT lives here — prompt assembly and response-shape
// validation stay in code (see lib/report-generation.ts).
model Prompt {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
